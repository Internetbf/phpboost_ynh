#!/bin/bash


source /usr/share/yunohost/helpers

#=================================================
# INITIALIZE AND STORE SETTINGS
#=================================================

ynh_app_setting_set --key=php_upload_max_filesize --value=256M
ynh_app_setting_set --key=php_post_max_size --value=256M

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Setting up source files..."

# Download, check integrity, uncompress and patch the source from app.src
ynh_setup_source --dest_dir="$install_dir"

#=================================================
# NGINX CONFIGURATION
#=================================================
ynh_script_progression "Configuring NGINX web server..."

# Create a dedicated NGINX config
ynh_config_add_nginx

# Create a dedicated PHP-FPM config
ynh_config_add_phpfpm

#=================================================
# NGINX CONFIGURATION
#=================================================
ynh_script_progression "Execute installation of __APP__..."

ynh_local_curl "/install/index.php?url=/database" "databaseForm_login=__DB_USER__" "databaseForm_password=__DB_PWD__" "databaseForm_schema=__DB_NAME__" #DB CURL
ynh_local_curl "/install/index.php?url=/website" "websiteForm_name=My WebSite" #General setings CURL
ynh_local_curl "/install/index.php?url=/admin" "adminForm_display_name=$phpboost_admin_user" "adminForm_email=$phpboost_admin_email" "adminForm_password=$phpboost_admin_psw" "adminForm_repeatPassword=$phpboost_admin_psw" #Admin CURL

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
